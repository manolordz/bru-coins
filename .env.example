# =============================================================================
# BRÜ COINS — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in all values before running the app.

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Keep secret! Never expose to client.

# --- Resend (email notifications) ---
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Change to your Vercel URL in production
